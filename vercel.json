{
  "builds": [
    {
      "src": "ia_betpredict/backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "ia_betpredict/backend/main.py"
    }
  ],
  "crons": [
    {
      "path": "/run-daily-job",
      "schedule": "0 0 * * *"
    }
  ]
}
