# ──────────────────────────────────────────────
# IA-BetPredict — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# NE JAMAIS commiter le fichier .env
# ──────────────────────────────────────────────

# Connexion PostgreSQL Neon (obligatoire)
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# Clé secrète pour protéger le endpoint /run-daily-job
# Génère une clé aléatoire : python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=change_me_with_a_random_secret

# Origines CORS autorisées (séparées par des virgules)
# En développement, laisser vide ou mettre * 
# En production : https://ia-betpredict.vercel.app
ALLOWED_ORIGINS=*
